---
Language: Cpp
BasedOnStyle: Google

# ==================== 基础缩进 ====================
IndentWidth: 4 # 缩进4空格（Google默认2，建议改成4）
TabWidth: 4
UseTab: Never # 禁止使用Tab，只用空格
AccessModifierOffset: -4 # public/private等访问修饰符缩进

# ==================== 行宽控制 ====================
ColumnLimit: 120 # 行宽120字符（现代显示器推荐，Google默认80太窄）
MaxEmptyLinesToKeep: 1 # 连续空行最多保留1行

# ==================== 大括号风格 ====================
BreakBeforeBraces: Custom # 自定义大括号换行
BraceWrapping:
  AfterCaseLabel: false # case 后面不换行
  AfterClass: false # class 后面不换行（Google风格）
  AfterControlStatement: false # if/for/while 后面不换行
  AfterEnum: false # enum 后面不换行
  AfterFunction: false # 函数定义后面不换行
  AfterNamespace: false # namespace 后面不换行
  AfterStruct: false # struct 后面不换行
  AfterUnion: false # union 后面不换行
  BeforeCatch: false # catch 前面不换行
  BeforeElse: false # else 前面不换行
  IndentBraces: false # 不缩进大括号

# ==================== 对齐规则 ====================
AlignAfterOpenBracket: Align # 开括号后参数对齐
AlignConsecutiveAssignments: # 连续赋值对齐
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true
  AlignCompound: false
  PadOperators: true
AlignConsecutiveDeclarations: # 连续声明对齐
  Enabled: false
  AcrossEmptyLines: false
  AcrossComments: true
AlignConsecutiveMacros: # 宏定义对齐（强烈推荐开启）
  Enabled: true
  AcrossEmptyLines: true
  AcrossComments: true
AlignEscapedNewlines: Right # 续行符右对齐
AlignOperands: Align # 操作数对齐
AlignTrailingComments: true # 行尾注释对齐

# ==================== 函数与参数 ====================
AllowShortFunctionsOnASingleLine: Empty # 只有空函数可以单行
AllowShortIfStatementsOnASingleLine: Never # if 语句禁止单行
AllowShortLoopsOnASingleLine: false # 循环禁止单行
AllowAllParametersOfDeclarationOnNextLine: true # 参数过多时允许换行
BinPackArguments: true # 参数打包（尽量放一行）
BinPackParameters: true # 函数参数打包

# ==================== 指针与引用 ====================
PointerAlignment: Right # 指针*靠右（int* ptr）
DerivePointerAlignment: false # 不推导，强制使用配置
ReferenceAlignment: Pointer # 引用&跟随指针设置

# ==================== 命名空间 ====================
NamespaceIndentation: None # namespace 内不额外缩进
FixNamespaceComments: true # 自动修复namespace结束注释
CompactNamespaces: false # 不压缩命名空间

# ==================== 继承与初始化 ====================
BreakInheritanceList: BeforeColon # 继承列表在冒号前换行
BreakConstructorInitializers: BeforeColon # 初始化列表在冒号前换行
ConstructorInitializerIndentWidth: 4 # 初始化列表缩进
ConstructorInitializerAllOnOneLineOrOnePerLine: false # 灵活处理初始化列表

# ==================== 模板与泛型 ====================
AlwaysBreakTemplateDeclarations: Yes # 模板声明总是换行
SpaceAfterTemplateKeyword: true # template 后面加空格

# ==================== 头文件与预处理 ====================
SortIncludes: CaseSensitive # 排序头文件（区分大小写）
IncludeBlocks: Preserve # 保留头文件分组
IndentPPDirectives: None # 预处理指令不缩进
PPIndentWidth: -1 # 使用默认缩进

# ==================== 空格控制 ====================
SpaceAfterCStyleCast: false # C风格转换后不加空格
SpaceAfterLogicalNot: false # ! 后面不加空格
SpaceBeforeAssignmentOperators: true # 赋值运算符前加空格
SpaceBeforeParens: ControlStatements # 控制语句前加空格
SpaceBeforeRangeBasedForLoopColon: true # for循环冒号前加空格
SpaceInEmptyBlock: false # 空代码块内不加空格
SpacesInParentheses: false # 圆括号内不加空格
SpacesInSquareBrackets: false # 方括号内不加空格
SpacesInContainerLiterals: true # 容器字面量内加空格 { 1, 2, 3 }
SpacesBeforeTrailingComments: 1 # 行尾注释前留1空格

# ==================== 换行与断行 ====================
BreakBeforeBinaryOperators: None # 二元运算符后换行
BreakBeforeTernaryOperators: true # 三元运算符前换行
BreakStringLiterals: true # 允许字符串断行
BreakConstructorInitializersBeforeComma: false

# ==================== 其他细节 ====================
Cpp11BracedListStyle: true # C++11列表初始化风格
KeepEmptyLinesAtTheStartOfBlocks: true # 保留块开头的空行
ReflowComments: true # 自动重排注释
SortUsingDeclarations: true # 排序using声明
Standard: Latest # 使用最新C++标准

# ==================== 惩罚值（影响换行决策） ====================
PenaltyBreakAssignment: 2
PenaltyBreakBeforeFirstCallParameter: 19
PenaltyBreakComment: 300
PenaltyBreakFirstLessLess: 120
PenaltyBreakString: 1000
PenaltyBreakTemplateDeclaration: 10
PenaltyExcessCharacter: 1000000
PenaltyReturnTypeOnItsOwnLine: 60
